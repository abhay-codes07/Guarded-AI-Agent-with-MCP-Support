# Copy to .env and fill in. .env is gitignored.

# --- LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Agent server ---
PORT=8787
# Comma-separated origins allowed to call the agent API (the dashboard).
CORS_ORIGIN=http://localhost:3000

# --- Intent signing (Ed25519). If left blank, an ephemeral keypair is generated at boot. ---
# Provide PKCS8 / SPKI PEM (base64 one-liners ok) to keep tokens stable across restarts.
INTENT_PRIVATE_KEY=
INTENT_PUBLIC_KEY=

# --- Guardrail tunables ---
APPROVAL_TTL_MS=60000
CIRCUIT_FAILS=3
CIRCUIT_RESET_MS=15000
TOOL_TIMEOUT_MS=15000
KILL_SWITCH_VIOLATIONS=5
MAX_LOOP_STEPS=12

# --- Remote MCP server (existing/public). DeepWiki needs no key; swap for Context7/Exa if you have one. ---
# Configured in mcp.config.json; keys (if any) referenced by env name there.
EXA_API_KEY=
CONTEXT7_API_KEY=
